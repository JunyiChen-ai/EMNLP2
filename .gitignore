.env

# Python caches
__pycache__/
*.pyc

# Nested repository metadata
**/.git/
archive/
archive/moe_refs/
datasets/
embeddings/

# Local build artifacts
build/
*.o
*.so

# Large model and checkpoint artifacts
*.pth
*.pt

# Large binary assets not needed for source publishing
*.pack
*.gif

# Large experiment outputs
archive/**/results/

# Slurm logs
log/

# Generated data (large, regenerate on target machine)
rationales/
results/

# Slurm scripts (machine-specific)
scripts/*.sbatch

# State files (machine-specific)
TARGET_LOOP_STATE.json
